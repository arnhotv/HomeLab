## Copy to credentials.auto.tfvars and fill with your values
## Do NOT commit the real file

# Proxmox
proxmox_api_url           = "https://<PROXMOX_HOST>:8006/api2/json"
proxmox_api_token_id      = "<USER@REALM!TOKEN_NAME>"
proxmox_api_token_secret  = "<TOKEN_SECRET>"

# Twingate
twingate_remote_network = "<TWINGATE_NETWORK_NAME>"
twingate_api_token      = "<TWINGATE_API_TOKEN>"

# Pi-hole (choose one method)
# pihole_api_token = "<PIHOLE_API_TOKEN>"
pihole_password    = "<PIHOLE_PASSWORD>"

